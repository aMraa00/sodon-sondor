# Render-ийн web service URL-ийг (жишээ: https://sodon-sondor-api.onrender.com) өөрийнхөөр соль
# Vercel: Project → Settings → Environment Variables
VITE_API_URL=https://sodon-sondor-api.onrender.com/api
# Socket: API-тай ижил host, гэхдээ /api байхгүй
VITE_SOCKET_URL=https://sodon-sondor-api.onrender.com
